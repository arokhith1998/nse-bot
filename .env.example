# ============================================
# NSE Market Intelligence Platform - Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Server ---
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# --- Database ---
DB_PATH=backend/data/nse_bot.db

# --- Trading Capital (INR) ---
CAPITAL=100000
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=6
MAX_SECTOR_CONCENTRATION_PCT=40
MAX_PORTFOLIO_HEAT_PCT=6
SINGLE_STOCK_MAX_PCT=20

# --- Market Hours (IST, 24h format) ---
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SQUARE_OFF_TIME=15:15

# --- Scan Schedule ---
SCAN_INTERVAL_MINUTES=15
NEWS_REFRESH_MINUTES=30
QUOTE_POLL_SECONDS=15

# --- Market Data Provider ---
# Options: composite, yfinance, nsepython
DEFAULT_DATA_PROVIDER=composite

# --- TradingView ---
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret-here

# --- Broker API Keys (for future integration) ---
# TODO: Zerodha Kite
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=

# TODO: Angel Broking SmartAPI
# ANGEL_API_KEY=
# ANGEL_CLIENT_ID=
# ANGEL_PASSWORD=
# ANGEL_TOTP_SECRET=

# TODO: Dhan
# DHAN_CLIENT_ID=
# DHAN_ACCESS_TOKEN=

# --- News API (optional, enhances news_ranker) ---
# NEWSAPI_KEY=
# FINSHOTS_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
